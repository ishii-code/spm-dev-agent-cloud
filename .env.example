# Local development: copy to .env and fill in real values.
# Cloud (GCE VM): values are injected via Secret Manager + envsubst at boot.

# === Database (Cloud SQL via Cloud SQL Auth Proxy on 127.0.0.1:5432) ===
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/spm_dev_agent?schema=public"

# === Obsidian Vault (local dev only; cloud version uses GCS or skip) ===
OBSIDIAN_VAULT_PATH="/path/to/Obsidian Vault"

# === Claude API ===
# Anthropic API key (per-employee usage tracked via Project.ownerId)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI API ===
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-5.5

# === Slack integration ===
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN=""

# === Admin bootstrap (used by prisma/seed.ts) ===
ADMIN_PASSWORD=""

# === Cloud-version additions (Phase 1+) ===
# JWT secret for spm_dev_session cookie (32+ bytes hex)
AUTH_SECRET=""
# Per-employee rate limit (calls/day) — K-α policy
RATE_LIMIT_PER_USER_PER_DAY=200

# === External service auth (Work Monitor 等) ===
# 外部サービスが POST /api/projects を叩く時に X-Service-Key で送る共有秘密
SERVICE_API_KEY=your-service-api-key

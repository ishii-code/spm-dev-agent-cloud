{
  "name": "spm-dev-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "kill-all": "ps -eo pid,command | grep SPM_RUN_ID | grep -v grep | awk '{print $1}' | xargs -r kill -9; psql spm_dev_agent -c \"UPDATE \\\"Document\\\" SET \\\"executionStatus\\\"='awaiting_approval', \\\"approvalState\\\"='approved', \\\"execPid\\\"=NULL, \\\"execDoneFile\\\"=NULL WHERE \\\"executionStatus\\\"='executing'; UPDATE \\\"Project\\\" SET \\\"parallelRunId\\\"=NULL, \\\"parallelStatus\\\"='paused';\"",
    "kill-project": "node scripts/kill-project.js",
    "status-all": "node scripts/status-all.js",
    "categorize": "npx tsx scripts/categorize-existing-projects.js"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.6",
    "node-pty": "^1.1.0",
    "openai": "^6.38.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
